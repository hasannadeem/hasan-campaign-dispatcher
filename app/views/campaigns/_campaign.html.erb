<%= link_to campaign, id: dom_id(campaign), class: "block rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:border-indigo-300 hover:shadow" do %>
  <div class="flex items-center justify-between">
    <div>
      <p class="font-medium text-slate-900"><%= campaign.title %></p>
      <p class="text-sm text-slate-500"><%= pluralize(campaign.recipients_count, "recipient") %></p>
    </div>
    <%= render "campaigns/status_badge", campaign: campaign %>
  </div>
<% end %>
