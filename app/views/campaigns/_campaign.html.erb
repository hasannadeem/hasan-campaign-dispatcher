<%= link_to campaign, id: dom_id(campaign), class: "block rounded-xl border border-zinc-200 bg-white p-4 shadow-sm transition hover:border-zinc-300 hover:shadow" do %>
  <div class="flex items-center justify-between">
    <div>
      <p class="font-medium text-zinc-900"><%= campaign.title %></p>
      <p class="text-sm text-zinc-500"><%= pluralize(campaign.recipients_count, "recipient") %></p>
    </div>
    <%= render "campaigns/status_badge", campaign: campaign %>
  </div>
  <div class="mt-3 flex items-center justify-between border-t border-zinc-100 pt-2 text-xs text-zinc-400">
    <span>Created <%= relative_time(campaign.created_at) %></span>
    <% unless campaign.pending? %>
      <span><%= campaign.processed_count %> sent<%= " · #{campaign.failed_count} failed" if campaign.failed_count.positive? %></span>
    <% end %>
  </div>
<% end %>
