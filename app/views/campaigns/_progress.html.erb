<%= turbo_frame_tag campaign.progress_dom_id, class: "block border-b border-slate-100 bg-slate-50 p-6" do %>
  <div class="flex items-center justify-between">
    <%= render "campaigns/status_badge", campaign: campaign %>
    <span class="text-sm font-medium text-slate-600" data-role="progress-count">
      Sent <%= campaign.sent_count %> of <%= campaign.recipients_count %>
    </span>
  </div>

  <div class="mt-3 h-2 w-full overflow-hidden rounded-full bg-slate-200">
    <div class="h-full rounded-full bg-indigo-600 transition-all duration-500"
         style="width: <%= campaign.progress_percent %>%"></div>
  </div>
<% end %>
