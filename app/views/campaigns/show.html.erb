<% content_for :title, @campaign.title %>
<%= turbo_stream_from @campaign %>

<div class="mb-6">
  <%= link_to "← All campaigns", root_path, class: "text-sm font-medium text-slate-500 hover:text-slate-900" %>
</div>

<div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
  <div class="flex items-start justify-between gap-4 border-b border-slate-100 p-6">
    <div>
      <h1 class="text-xl font-semibold text-slate-900"><%= @campaign.title %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= pluralize(@campaign.recipients_count, "recipient") %></p>
    </div>

    <% if @campaign.pending? %>
      <%= button_to "Start dispatch", start_campaign_path(@campaign),
            class: "rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500" %>
    <% end %>
  </div>

  <%= render "campaigns/progress", campaign: @campaign %>

  <ul id="recipients" class="divide-y divide-slate-100">
    <%= render @campaign.recipients %>
  </ul>
</div>
