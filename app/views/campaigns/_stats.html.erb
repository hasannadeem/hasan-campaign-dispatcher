<dl class="grid grid-cols-2 gap-4 sm:grid-cols-4">
  <% [
       ["Campaigns",   stats.total_campaigns,  "text-zinc-900"],
       ["Recipients",  stats.total_recipients, "text-zinc-900"],
       ["Emails sent", stats.emails_sent,      "text-emerald-600"],
       ["Active",      stats.active_campaigns, "text-amber-600"]
     ].each do |label, value, accent| %>
    <div class="rounded-xl border border-zinc-200 bg-white p-4 shadow-sm">
      <dt class="text-xs font-medium uppercase tracking-wide text-zinc-500"><%= label %></dt>
      <dd class="mt-1 text-2xl font-semibold tracking-tight <%= accent %>"><%= number_with_delimiter(value) %></dd>
    </div>
  <% end %>
</dl>
